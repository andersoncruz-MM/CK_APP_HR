# ============================================
# CHICKEN KITCHEN HR - Streamlit Secrets
# ============================================
# Copy this file to secrets.toml and fill in your values.
# DO NOT commit secrets.toml to Git!
#
# For Streamlit Cloud: paste these values in the
# app dashboard under Settings > Secrets.
# ============================================

[email]
# Gmail address that will SEND the verification codes
sender = "your-email@gmail.com"

# Gmail App Password (NOT your regular password)
# To create one:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification (if not already)
#   3. Go to https://myaccount.google.com/apppasswords
#   4. Select "Mail" and "Other (Custom name)" > "Chicken Kitchen HR"
#   5. Copy the 16-character password here (no spaces)
app_password = "abcdefghijklmnop"

[app]
# Your Streamlit Cloud app URL (for the QR code)
url = "https://ck-hr-forms.streamlit.app"
