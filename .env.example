# ============================================
# Chicken Kitchen HR - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to Git!
#
# SETUP:
# 1. Create a free Supabase account at https://supabase.com
# 2. Create a new project
# 3. Go to SQL Editor, paste api/migration.sql, and run it
# 4. Go to Settings > API to find your URL and anon key
# 5. Fill in the values below
# ============================================

# Supabase (free PostgreSQL database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# Gmail SMTP (same credentials as Streamlit)
SMTP_SENDER=andersonckllc@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# App URL (for admin review links in emails)
# Change this when you deploy to a real domain
APP_BASE_URL=http://localhost:8000
